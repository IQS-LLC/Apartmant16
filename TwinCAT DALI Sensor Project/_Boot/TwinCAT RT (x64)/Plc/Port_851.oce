		<Event>
			<Id>28</Id>
			<Message LcId="1031"><![CDATA[Die Antwort von der Instanz ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) des DALI-Geräts ('nAddress': {2} / 'eAddressType': {3}) ist ungültig.]]></Message>
			<Message LcId="1033"><![CDATA[The response from the instance ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) of the DALI device ('nAddress': {2} / 'eAddressType': {3}) is invalid.]]></Message>
		</Event>
		<Event>
			<Id>29</Id>
			<Message LcId="1031">Dieser DALI-Befehl wird von der Simulation nicht unterstützt.</Message>
			<Message LcId="1033">This DALI command is not supported by the simulation.</Message>
		</Event>
		<Event>
			<Id>30</Id>
			<Message LcId="1031">Der Zugriff auf den Befehlspuffer ist wegen einer Blockierung durch den Mutex nicht möglich.</Message>
			<Message LcId="1033">Access to the command buffer is not possible because of a blocking by the mutex.</Message>
		</Event>
		<Event>
			<Id>31</Id>
			<Message LcId="1031">Der Eintrag im Empfangsbuffer der KL6821/EL6821 hat einen Fehler im Bit-Timing.</Message>
			<Message LcId="1033">The item in the receive buffer of the KL6821/EL6821 has an error in bit timing.</Message>
		</Event>
		<Event>
			<Id>32</Id>
