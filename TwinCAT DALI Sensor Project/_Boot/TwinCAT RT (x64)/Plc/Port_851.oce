		<Name LcId="1031">TcDALIEventClass</Name>
		<Name LcId="1033">TcDALIEventClass</Name>
		<Event>
			<Id>1</Id>
			<Message LcId="1031">Keine Antwort von der DALI-Klemme.</Message>
			<Message LcId="1033">No response from the DALI terminal.</Message>
		</Event>
		<Event>
			<Id>2</Id>
			<Message LcId="1031"><![CDATA[Keine Antwort vom DALI-Gerät ('nAddress': {0} / 'eAddressType': {1}).]]></Message>
			<Message LcId="1033"><![CDATA[No response from the DALI device ('nAddress': {0} / 'eAddressType': {1}).]]></Message>
		</Event>
		<Event>
			<Id>3</Id>
			<Message LcId="1031">Überlauf Befehlspuffer.</Message>
			<Message LcId="1033">Command buffer overflow.</Message>
		</Event>
		<Event>
			<Id>4</Id>
			<Message LcId="1031">Keine Antwort von dem Kommunikationsbaustein.</Message>
			<Message LcId="1033">No answer from the communication block.</Message>
		</Event>
		<Event>
			<Id>5</Id>
			<Message LcId="1031">Während der Übertragung eines DALI-Telegramms wurde auf dem Rückkanal (Backward Channel) eine Kollision mit den Sendedaten eines anderen DALI-Gerät erkannt.</Message>
			<Message LcId="1033">DALI collision detected on the backward channel: during the transfer of a DALI telegram, a collision with the transmit data of another DALI device was detected.</Message>
		</Event>
		<Event>
			<Id>6</Id>
			<Message LcId="1031">Während der Übertragung eines DALI-Telegramms wurde auf dem Hinkanal (Forward Channel) eine Kollision mit den Sendedaten eines anderen DALI-Steuergerät erkannt. Der Fehler tritt auch auf, sobald die 24 V an der Busklemme fehlen.</Message>
			<Message LcId="1033">DALI collision detected on the forward channel: during the transfer of a DALI telegram, a collision with the transmit data of another DALI control device was detected. The error also occurs if the 24 V supply is missing at the power contacts of the bus terminal.</Message>
		</Event>
		<Event>
			<Id>7</Id>
			<Message LcId="1031">Überlastung des internen DALI-Netzteils der Busklemme (Busunterspannung).</Message>
			<Message LcId="1033">Overload of the internal DALI power supply unit of the bus terminal (bus under-voltage).</Message>
		</Event>
		<Event>
			<Id>8</Id>
			<Message LcId="1031">Bei Nutzung des internen DALI-Netzteils: Fehler Netzteil erkannt.</Message>
			<Message LcId="1033">When using the internal DALI power supply unit: Power supply unit fault detected.</Message>
		</Event>
		<Event>
			<Id>9</Id>
			<Message LcId="1031">Prozessabbild wurde durch die Eingänge DI1 oder DI2 der Klemme deaktiviert.</Message>
			<Message LcId="1033">The process image was disabled by the DI1 or DI2 inputs of the terminal.</Message>
		</Event>
		<Event>
			<Id>10</Id>
			<Message LcId="1031">Die 24 V DC Versorgungsspannung an den Anschlüssen 1 und 5 der KL6821/EL6821 fehlt, oder es wurde ein Kurzschluss auf dem DALI-Bus erkannt.</Message>
			<Message LcId="1033">Missing the 24 V DC input voltage at pin 1 and 5 of the KL6821/EL6821 or short-circuit detected on the DALI bus.</Message>
		</Event>
		<Event>
			<Id>11</Id>
			<Message LcId="1031">Auf Grund von Kollisionen auf dem DALI-Bus konnte der DALI-Befehl nicht versendet werden.</Message>
			<Message LcId="1033">Because there are collisions on the DALI bus, the DALI command could not be sent.</Message>
		</Event>
		<Event>
			<Id>12</Id>
			<Message LcId="1031">Der Eintrag im Empfangsbuffer der KL6821/EL6821 ist ungültig.</Message>
			<Message LcId="1033">The item in the receive buffer of the KL6821/EL6821 is invalid.</Message>
		</Event>
		<Event>
			<Id>13</Id>
			<Message LcId="1031">Der Interface-Pointer auf den Kommunikationsbaustein ist nicht initialisiert.</Message>
			<Message LcId="1033">The interface pointer to the communication function block is not initialized.</Message>
		</Event>
		<Event>
			<Id>14</Id>
			<Message LcId="1031">Der Befehlspuffer wurde länger blockiert als erlaubt.</Message>
			<Message LcId="1033">The command buffer has been blocked for longer than permitted.</Message>
		</Event>
		<Event>
			<Id>15</Id>
			<Message LcId="1031">Bei der Adressierung hat die Klemme einen Fehler zurückgeliefert.</Message>
			<Message LcId="1033">The terminal has returned an error during addressing.</Message>
		</Event>
		<Event>
			<Id>16</Id>
			<Message LcId="1031">Bei der Adressierung hat die Klemme einen Kurzschluss auf dem Bus erkannt.</Message>
			<Message LcId="1033">During addressing the terminal has detected a short circuit on the bus.</Message>
		</Event>
		<Event>
			<Id>17</Id>
			<Message LcId="1031">Bei der Adressierung hat die Klemme erkannt, dass keine freie Kurzadresse vorhanden ist.</Message>
			<Message LcId="1033">During addressing the terminal has detected that there is no further short address available.</Message>
		</Event>
		<Event>
			<Id>18</Id>
			<Message LcId="1031">Bei der Adressierung hat die Klemme erkannt, dass mehrere Geräte die gleiche Langadresse besitzen.</Message>
			<Message LcId="1033">During addressing the terminal has detected that several devices have the same long address.</Message>
		</Event>
		<Event>
			<Id>19</Id>
			<Message LcId="1031">Die Adressierung ist 3x fehlgeschlagen.</Message>
			<Message LcId="1033">Addressing has failed 3 times.</Message>
		</Event>
		<Event>
			<Id>20</Id>
			<Message LcId="1031">Zeitüberschreitung bei der Adressierung. Die Klemme hat nach dem Starten der Adressierung keine Antwort zurückgeliefert.</Message>
			<Message LcId="1033">Timeout during addressing. The terminal has not sent a reply following the start of addressing.</Message>
		</Event>
		<Event>
			<Id>21</Id>
			<Message LcId="1031"><![CDATA[Keine Antwort von der Instanz ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) des DALI-Geräts ('nAddress': {2} / 'eAddressType': {3}).]]></Message>
			<Message LcId="1033"><![CDATA[No response from the instance ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) of the DALI device ('nAddress': {2} / 'eAddressType': {3}).]]></Message>
		</Event>
		<Event>
			<Id>22</Id>
			<Message LcId="1031">Die KL6811 unterstützt nur 16 Bit Befehle (IEC 62386-102 und IEC 62386-2xx).</Message>
			<Message LcId="1033">The KL6811 supports only 16 Bit commands (IEC 62386-102 and IEC 62386-2xx).</Message>
		</Event>
		<Event>
			<Id>23</Id>
			<Message LcId="1031">Während der Konfiguration der Klemme ist ein Fehler aufgetreten.</Message>
			<Message LcId="1033">An error occurred during configuration of the terminal.</Message>
		</Event>
		<Event>
			<Id>24</Id>
			<Message LcId="1031">Keine Antwort vom DALI-Gerät.</Message>
			<Message LcId="1033">No response from the DALI Device.</Message>
		</Event>
		<Event>
			<Id>25</Id>
			<Message LcId="1031">Es ist keine freie Kurzadresse mehr vorhanden.</Message>
			<Message LcId="1033">There is no further short address available.</Message>
		</Event>
		<Event>
			<Id>26</Id>
			<Message LcId="1031">Während der Adressierung ist ein Fehler aufgetreten.</Message>
			<Message LcId="1033">An error occurred during addressing.</Message>
		</Event>
		<Event>
			<Id>27</Id>
			<Message LcId="1031"><![CDATA[Die Antwort vom DALI-Gerät ('nAddress': {0} / 'eAddressType': {1}) ist ungültig.]]></Message>
			<Message LcId="1033"><![CDATA[The response from the DALI device is invalid ('nAddress': {0} / 'eAddressType': {1}).]]></Message>
