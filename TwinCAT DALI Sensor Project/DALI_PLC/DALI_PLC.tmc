entId><Name Id="274">ParameterFadeTimeLiesOutsideOfTheValidRange</Name><DisplayName TxtId=""><![CDATA[ParameterFadeTimeLiesOutsideOfTheValidRange]]></DisplayName><Severity>Error</Severity></EventId><EventId><Name Id="275">ParameterFadeRateLiesOutsideOfTheValidRange</Name><DisplayName TxtId=""><![CDATA[ParameterFadeRateLiesOutsideOfTheValidRange]]></DisplayName><Severity>Error</Severity></EventId><EventId><Name Id="276">ParameterNewShortAddressLiesOutsideOfTheValidRange</Name><DisplayName TxtId=""><![CDATA[ParameterNewShortAddressLiesOutsideOfTheValidRange]]></DisplayName><Severity>Error</Severity></EventId><EventId><Name Id="277">ParameterStartWithShortAddressLiesOutsideOfTheValidRange</Name><DisplayName TxtId=""><![CDATA[ParameterStartWithShortAddressLiesOutsideOfTheValidRange]]></DisplayName><Severity>Error</Severity></EventId><Translations><Text TxtId="TcDALIEventClass"><Text LcId="1031"><![CDATA[TcDALIEventClass]]></Text><Text LcId="1033"><![CDATA[TcDALIEventClass]]></Text></Text><Text TxtId="NoResponseFromTheDALITerminal"><Text LcId="1031"><![CDATA[Keine Antwort von der DALI-Klemme.]]></Text><Text LcId="1033"><![CDATA[No response from the DALI terminal.]]></Text></Text><Text TxtId="NoResponseFromTheDALIDevice"><Text LcId="1031"><![CDATA[Keine Antwort vom DALI-Gerät ('nAddress': {0} / 'eAddressType': {1}).]]></Text><Text LcId="1033"><![CDATA[No response from the DALI device ('nAddress': {0} / 'eAddressType': {1}).]]></Text></Text><Text TxtId="CommandBufferOverflow"><Text LcId="1031"><![CDATA[Überlauf Befehlspuffer.]]></Text><Text LcId="1033"><![CDATA[Command buffer overflow.]]></Text></Text><Text TxtId="NoAnswerFromTheCommunicationBlock"><Text LcId="1031"><![CDATA[Keine Antwort von dem Kommunikationsbaustein.]]></Text><Text LcId="1033"><![CDATA[No answer from the communication block.]]></Text></Text><Text TxtId="DALICollisionDetectedOnTheBackwardChannel"><Text LcId="1031"><![CDATA[Während der Übertragung eines DALI-Telegramms wurde auf dem Rückkanal (Backward Channel) eine Kollision mit den Sendedaten eines anderen DALI-Gerät erkannt.]]></Text><Text LcId="1033"><![CDATA[DALI collision detected on the backward channel: during the transfer of a DALI telegram, a collision with the transmit data of another DALI device was detected.]]></Text></Text><Text TxtId="DALICollisionDetectedOnTheForwardChannel"><Text LcId="1031"><![CDATA[Während der Übertragung eines DALI-Telegramms wurde auf dem Hinkanal (Forward Channel) eine Kollision mit den Sendedaten eines anderen DALI-Steuergerät erkannt. Der Fehler tritt auch auf, sobald die 24 V an der Busklemme fehlen.]]></Text><Text LcId="1033"><![CDATA[DALI collision detected on the forward channel: during the transfer of a DALI telegram, a collision with the transmit data of another DALI control device was detected. The error also occurs if the 24 V supply is missing at the power contacts of the bus terminal.]]></Text></Text><Text TxtId="OverloadOfTheInternalDALIPowerSupplyUnitOfTheBusTerminal_BusUnderVoltage"><Text LcId="1031"><![CDATA[Überlastung des internen DALI-Netzteils der Busklemme (Busunterspannung).]]></Text><Text LcId="1033"><![CDATA[Overload of the internal DALI power supply unit of the bus terminal (bus under-voltage).]]></Text></Text><Text TxtId="PowerSupplyUnitFaultDetected"><Text LcId="1031"><![CDATA[Bei Nutzung des internen DALI-Netzteils: Fehler Netzteil erkannt.]]></Text><Text LcId="1033"><![CDATA[When using the internal DALI power supply unit: Power supply unit fault detected.]]></Text></Text><Text TxtId="TheProcessImageWasDisabledByDI1OrDI2"><Text LcId="1031"><![CDATA[Prozessabbild wurde durch die Eingänge DI1 oder DI2 der Klemme deaktiviert.]]></Text><Text LcId="1033"><![CDATA[The process image was disabled by the DI1 or DI2 inputs of the terminal.]]></Text></Text><Text TxtId="ShortCircuitDetectedOnTheDALIBus"><Text LcId="1031"><![CDATA[Die 24 V DC Versorgungsspannung an den Anschlüssen 1 und 5 der KL6821/EL6821 fehlt, oder es wurde ein Kurzschluss auf dem DALI-Bus erkannt.]]></Text><Text LcId="1033"><![CDATA[Missing the 24 V DC input voltage at pin 1 and 5 of the KL6821/EL6821 or short-circuit detected on the DALI bus.]]></Text></Text><Text TxtId="CollisionErrorOnTheDALIBus"><Text LcId="1031"><![CDATA[Auf Grund von Kollisionen auf dem DALI-Bus konnte der DALI-Befehl nicht versendet werden.]]></Text><Text LcId="1033"><![CDATA[Because there are collisions on the DALI bus, the DALI command could not be sent.]]></Text></Text><Text TxtId="ItemInReceiveBufferIsInvalid"><Text LcId="1031"><![CDATA[Der Eintrag im Empfangsbuffer der KL6821/EL6821 ist ungültig.]]></Text><Text LcId="1033"><![CDATA[The item in the receive buffer of the KL6821/EL6821 is invalid.]]></Text></Text><Text TxtId="TheInterfaceToTheCommunicationBufferIsNotInitialized"><Text LcId="1031"><![CDATA[Der Interface-Pointer auf den Kommunikationsbaustein ist nicht initialisiert.]]></Text><Text LcId="1033"><![CDATA[The interface pointer to the communication function block is not initialized.]]></Text></Text><Text TxtId="TheCommandBuffersHaveBeenBlockedForLongerThanPermitted"><Text LcId="1031"><![CDATA[Der Befehlspuffer wurde länger blockiert als erlaubt.]]></Text><Text LcId="1033"><![CDATA[The command buffer has been blocked for longer than permitted.]]></Text></Text><Text TxtId="TheTerminalHasReturnedAnErrorDuringInternalAddressing"><Text LcId="1031"><![CDATA[Bei der Adressierung hat die Klemme einen Fehler zurückgeliefert.]]></Text><Text LcId="1033"><![CDATA[The terminal has returned an error during addressing.]]></Text></Text><Text TxtId="DuringInternalAddressingTheTerminalHasDetectedAShortCircuitOnTheBus"><Text LcId="1031"><![CDATA[Bei der Adressierung hat die Klemme einen Kurzschluss auf dem Bus erkannt.]]></Text><Text LcId="1033"><![CDATA[During addressing the terminal has detected a short circuit on the bus.]]></Text></Text><Text TxtId="DuringInternalAddressingTheTerminalHasDetectedThatThereIsNoFurtherShortAddressAvailable"><Text LcId="1031"><![CDATA[Bei der Adressierung hat die Klemme erkannt, dass keine freie Kurzadresse vorhanden ist.]]></Text><Text LcId="1033"><![CDATA[During addressing the terminal has detected that there is no further short address available.]]></Text></Text><Text TxtId="DuringInternalAddressingTheTerminalHasDetectedThatSeveralDevicesHaveTheSameLongAddress"><Text LcId="1031"><![CDATA[Bei der Adressierung hat die Klemme erkannt, dass mehrere Geräte die gleiche Langadresse besitzen.]]></Text><Text LcId="1033"><![CDATA[During addressing the terminal has detected that several devices have the same long address.]]></Text></Text><Text TxtId="InternalAddressingHasFailed3Times"><Text LcId="1031"><![CDATA[Die Adressierung ist 3x fehlgeschlagen.]]></Text><Text LcId="1033"><![CDATA[Addressing has failed 3 times.]]></Text></Text><Text TxtId="TimeoutDuringInternalAddressing"><Text LcId="1031"><![CDATA[Zeitüberschreitung bei der Adressierung. Die Klemme hat nach dem Starten der Adressierung keine Antwort zurückgeliefert.]]></Text><Text LcId="1033"><![CDATA[Timeout during addressing. The terminal has not sent a reply following the start of addressing.]]></Text></Text><Text TxtId="NoResponseFromTheDALIDeviceInstance"><Text LcId="1031"><![CDATA[Keine Antwort von der Instanz ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) des DALI-Geräts ('nAddress': {2} / 'eAddressType': {3}).]]></Text><Text LcId="1033"><![CDATA[No response from the instance ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) of the DALI device ('nAddress': {2} / 'eAddressType': {3}).]]></Text></Text><Text TxtId="TheKL6811DoesNotSupportThisDALICommand"><Text LcId="1031"><![CDATA[Die KL6811 unterstützt nur 16 Bit Befehle (IEC 62386-102 und IEC 62386-2xx).]]></Text><Text LcId="1033"><![CDATA[The KL6811 supports only 16 Bit commands (IEC 62386-102 and IEC 62386-2xx).]]></Text></Text><Text TxtId="ErrorDuringTheConfigurationOfTheTerminal"><Text LcId="1031"><![CDATA[Während der Konfiguration der Klemme ist ein Fehler aufgetreten.]]></Text><Text LcId="1033"><![CDATA[An error occurred during configuration of the terminal.]]></Text></Text><Text TxtId="NoResponseFromTheDALIDevice2"><Text LcId="1031"><![CDATA[Keine Antwort vom DALI-Gerät.]]></Text><Text LcId="1033"><![CDATA[No response from the DALI Device.]]></Text></Text><Text TxtId="NoFreeShortAddressAvailable"><Text LcId="1031"><![CDATA[Es ist keine freie Kurzadresse mehr vorhanden.]]></Text><Text LcId="1033"><![CDATA[There is no further short address available.]]></Text></Text><Text TxtId="ErrorDuringAddressing"><Text LcId="1031"><![CDATA[Während der Adressierung ist ein Fehler aufgetreten.]]></Text><Text LcId="1033"><![CDATA[An error occurred during addressing.]]></Text></Text><Text TxtId="InvalidResponseFromTheDALIDevice"><Text LcId="1031"><![CDATA[Die Antwort vom DALI-Gerät ('nAddress': {0} / 'eAddressType': {1}) ist ungültig.]]></Text><Text LcId="1033"><![CDATA[The response from the DALI device is invalid ('nAddress': {0} / 'eAddressType': {1}).]]></Text></Text><Text TxtId="InvalidResponseFromTheDALIDeviceInstance"><Text LcId="1031"><![CDATA[Die Antwort von der Instanz ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) des DALI-Geräts ('nAddress': {2} / 'eAddressType': {3}) ist ungültig.]]></Text><Text LcId="1033"><![CDATA[The response from the instance ('nInstanceAddress': {0} / 'eInstanceAddressType': {1}) of the DALI device ('nAddress': {2} / 'eAddressType': {3}) is invalid.]]></Text></Text><Text TxtId="ThisDALICommandIsNotSupportedByTheSimulation"><Text LcId="1031"><![CDATA[Dieser DALI-Befehl wird von der Simulation nicht unterstützt.]]></Text><Text LcId="1033"><![CDATA[This DALI command is not supported by the simulation.]]></Text></Text><Text TxtId="CommandBuffersBlockedByMutex"><Text LcId="1031"><![CDATA[Der Zugriff auf den Befehlspuffer ist wegen einer Blockierung durch den Mutex nicht möglich.]]></Text><Text LcId="1033"><![CDATA[Access to the command buffer is not possible because of a blocking by the mutex.]]></Text></Text><Text TxtId="ItemInR